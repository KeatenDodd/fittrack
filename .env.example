# Copy to .env and adjust. .env is read at startup.

# Where the server listens. 0.0.0.0 = reachable from other devices on your LAN.
HOST=0.0.0.0
PORT=1308

# Postgres connection string.
DATABASE_URL=postgres://fittrack:fittrack@localhost:5432/fittrack

# Secret used to sign login tokens. Change this to a long random string.
JWT_SECRET=xhmVAE475hQYJjmFv62CvdyV7fIxwjDkc3uRFaDPeF3fExrHLE

# Access token lifetime / refresh token lifetime (days).
ACCESS_TTL=30m
REFRESH_DAYS=60

# Directory holding cert.pem + key.pem (from mkcert). If both files are
# missing the server falls back to plain HTTP (camera/barcode will not work).
CERT_DIR=./certs

# Open Food Facts base URL (used for barcode + food search).
OFF_BASE=https://world.openfoodfacts.org
